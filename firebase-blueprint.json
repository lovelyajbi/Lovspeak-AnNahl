{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Core user profile and status",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "level": { "type": "string", "enum": ["A1", "A2", "B1", "B2", "C1", "C2"] },
        "xp": { "type": "integer" },
        "isActive": { "type": "boolean" },
        "activatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "isActive"]
    },
    "DiaryEntry": {
      "title": "Diary Entry",
      "description": "A user's learning diary entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" }
      },
      "required": ["id", "date", "title", "content"]
    },
    "VocabItem": {
      "title": "Vocabulary Item",
      "description": "A user's saved vocabulary word",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "english": { "type": "string" },
        "indonesian": { "type": "string" },
        "category": { "type": "string" },
        "isUserGenerated": { "type": "boolean" }
      },
      "required": ["id", "english", "indonesian"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Log of a user's learning activity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "date": { "type": "string" },
        "durationSeconds": { "type": "integer" },
        "score": { "type": "integer" },
        "accuracy": { "type": "integer" },
        "details": { "type": "string" }
      },
      "required": ["id", "type", "date"]
    },
    "LearningPlan": {
      "title": "Learning Plan",
      "description": "User's personalized learning plan",
      "type": "object",
      "properties": {
        "targetIds": { "type": "array", "items": { "type": "string" } },
        "intensityId": { "type": "string" },
        "currentLevel": { "type": "string" },
        "daysPerWeek": { "type": "integer" },
        "lastGeneratedDate": { "type": "string" }
      }
    },
    "MasterSettings": {
      "title": "Master Settings",
      "description": "Global application settings like activation code",
      "type": "object",
      "properties": {
        "activationCode": { "type": "string" }
      },
      "required": ["activationCode"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/users/{uid}/reading_progress/{progId}": {
      "schema": { "type": "object" },
      "description": "User's reading progress logs"
    },
    "/users/{uid}/reading_cache/{cacheId}": {
      "schema": { "type": "object" },
      "description": "Cached reading content"
    },
    "/users/{uid}/diary/{entryId}": {
      "schema": "DiaryEntry",
      "description": "User's diary entries"
    },
    "/users/{uid}/vocab/{vocabId}": {
      "schema": "VocabItem",
      "description": "User's vocabulary list"
    },
    "/users/{uid}/activity/{logId}": {
      "schema": "ActivityLog",
      "description": "User's activity history"
    },
    "/users/{uid}/settings/plan": {
      "schema": "LearningPlan",
      "description": "User's learning plan"
    },
    "/settings/master": {
      "schema": "MasterSettings",
      "description": "Global master settings"
    }
  }
}
